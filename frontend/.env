# Frontend Configuration
VITE_API_URL=http://localhost:5000

# Backend Configuration (for reference)
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=travel_planner
DB_PORT=3306
DB_DIALECT=mysql

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=90d
JWT_COOKIE_EXPIRES_IN=90

# API Keys (add your actual API keys here)
WEATHER_API_KEY=your_weather_api_key
FLIGHT_API_KEY=your_flight_api_key
HOTEL_API_KEY=your_hotel_api_key

# Google Sign-In (OAuth 2.0 Web Client ID from Google Cloud → APIs & Services → Credentials)
# Paste the same value into Backend/.env as GOOGLE_CLIENT_ID. You can set either line below (or both).
VITE_GOOGLE_CLIENT_ID=173690392988-lib42gq9t5j553p8v1bpp6frrfu7aedl.apps.googleusercontent.com
GOOGLE_CLIENT_ID=173690392988-lib42gq9t5j553p8v1bpp6frrfu7aedl.apps.googleusercontent.com
